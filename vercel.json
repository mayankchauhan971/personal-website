{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "rewrites": [
    {
      "source": "/notes2content",
      "destination": "https://notes2content.up.railway.app"
    },
    {
      "source": "/notes2content/:path*",
      "destination": "https://notes2content.up.railway.app/:path*"
    }
  ]
}
